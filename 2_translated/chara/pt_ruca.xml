<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Ruca</JapaneseText>
      <EnglishText>Ruca</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>頑張ってついていくよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_200_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>な、なんとかがんばろうね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_201_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>強引に行くの！？　ま、待ってよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_202_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>足は引っ張らないように気をつけるよ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_203_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>置いてかないでね。約束だよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_204_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>海から敵とか……現れないよね？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_205_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>い、行くしかないんだよね……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_206_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>二人でがんばろうね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_207_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>すごいよ！　さすがだね！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_208_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>今の動き、とってもよかったよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_209_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕も負けないようにがんばらなきゃ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_210_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どんどん倒しちゃうんだね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_211_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>本当にすごいね！　僕も見習わなきゃ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_212_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うわー、楽に勝つんだね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_213_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あ、あんまり一人でがんばらないでね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_214_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕って、邪魔なだけなのかな？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_215_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やったね！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_216_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>その調子だよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_217_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あの……少し手加減してあげた方が……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_218_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やりづらいよね。相手がこれじゃ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_219_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕達に近寄らないで！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_220_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あ、怪我……大丈夫ですか？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_221_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さすが、僕なんかとはちがうね！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_222_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんな数、僕にはとても無理だよ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_223_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>一人でそんなに倒すなんて、すごすぎるよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_224_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もうそんなに！？　すごすぎてもう……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_225_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>仲間が一騎当千なんて、なんだか僕まで誇らしいよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_226_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>今日はとっても技のキレがいいね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_227_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>すごい！　まだ止まらないんだ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_228_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕じゃとてもついていけないよ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_229_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕、足手まといにしかならないんじゃ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_230_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなすごい戦い方があるなんて……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_231_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>一人で戦局を変える程の強さ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_232_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>気にしないで。僕もたいした事ないから</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_233_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>きっと、もっとやれるよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_234_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うん！　調子出てきたみたいだね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_235_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>安心して一緒に戦えるよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_236_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>36</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕なんかじゃ、邪魔になるんじゃ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_237_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>一緒に戦えば、僕も強くなれるかもしれない</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_238_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>38</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>体力に気をつけてね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_239_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>39</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>体力が減ってるよ！　回復しなきゃ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_240_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>40</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ま、まずいよ！　いったん逃げた方が！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_241_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>41</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>行くん……だよね？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_242_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>42</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>また敵が！？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_243_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>43</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>大丈夫！？　怪我、見せてみて！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_244_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>44</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕が……僕ががんばらないと……！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_245_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>45</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やっぱり僕じゃ……ダメなの？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_246_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>46</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ま、待ってよ！　置いてかないで！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_247_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>47</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
