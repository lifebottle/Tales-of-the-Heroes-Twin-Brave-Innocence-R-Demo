<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Marta</JapaneseText>
      <EnglishText>Marta</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>手強い敵みたいだね</JapaneseText>
      <EnglishText>Looks like a tough opponent.</EnglishText>
      <Notes>Audio file: na/NA04_300_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>嘘……圧倒的すぎるよ……</JapaneseText>
      <EnglishText>No way... This is too much...</EnglishText>
      <Notes>Audio file: na/NA04_301_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どうしよう、誰も止められないみたい</JapaneseText>
      <EnglishText>What should I do? It doesn't look like anyone can stop them.</EnglishText>
      <Notes>Audio file: na/NA04_302_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これ以上やらせるわけにはいかないよ！</JapaneseText>
      <EnglishText>I can't let you keep doing this!</EnglishText>
      <Notes>Audio file: na/NA04_303_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あの敵、要注意だね</JapaneseText>
      <EnglishText>I've gotta be cautious around this enemy.</EnglishText>
      <Notes>Audio file: na/NA04_304_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まだ止まらないっていうの！？</JapaneseText>
      <EnglishText>They're still not stopping?!</EnglishText>
      <Notes>Audio file: na/NA04_305_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなにすごい人がいるなんて……</JapaneseText>
      <EnglishText>I can't believe there's someone like this out there...</EnglishText>
      <Notes>Audio file: na/NA04_306_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>早くなんとかしなきゃ……</JapaneseText>
      <EnglishText>I've gotta do something fast...</EnglishText>
      <Notes>Audio file: na/NA04_307_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これ以上はやらせない……！</JapaneseText>
      <EnglishText>I won't let you do this any longer...!</EnglishText>
      <Notes>Audio file: na/NA04_308_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>私に……止められるの？</JapaneseText>
      <EnglishText>Can I... not stop them?</EnglishText>
      <Notes>Audio file: na/NA04_309_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>絶対に許さない！</JapaneseText>
      <EnglishText>I will absolutely not forgive you!</EnglishText>
      <Notes>Audio file: na/NA04_310_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>おとなしく退いてはくれないんだね……</JapaneseText>
      <EnglishText>So you won't just quietly turn back, huh...</EnglishText>
      <Notes>Audio file: na/NA04_311_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ラタトスク……私を守って！</JapaneseText>
      <EnglishText>Ratatosk... protect me!</EnglishText>
      <Notes>Audio file: na/NA04_312_022.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
</SceneText>
