<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Spada</JapaneseText>
      <EnglishText>Spada</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いくぞ、コラァ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_100_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>暴れてんじゃねェぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_101_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>邪魔すんじゃねェよ！　どけコラァ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_102_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>怪我したくねェんだったら失せな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_103_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さっさと片付けてやンよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_104_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>沈められてェのか？　アァ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_105_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>仰々しいモン作りやがって</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_106_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>世界樹ってのはご立派だなァ、おい</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_107_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>話にならねェなぁ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_108_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どんどんかかってこいよぉ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_109_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんなに斬り刻まれてェのか？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_110_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ハンッ！　ウゼェだけだな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_111_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>相手にならねェなぁ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_112_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>覚悟は出来てンだろうなぁ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_113_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレの邪魔すンじゃねェよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_114_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなもんかぁ？　あぁ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_115_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ほら、さっさと次来いよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_116_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ハナシにもなんねェぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_117_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>怪我してェのかよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_118_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あー、ウッゼェな！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_119_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>斬られても文句は言うなよ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_120_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>覚悟もねェのに出てくんな！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_121_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>死なねェ程度には手ェ抜いてやったぞ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_122_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まさかそのくれェで降参しねェよなぁ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_123_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もっとふんばれや！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_124_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ヤバかったらさっさと逃げろ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_125_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>とっとと行くぞ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_126_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ザコがウジャウジャ出てくンじゃねェよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_127_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>万倍にして後悔させてやらぁ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_128_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>テメェはさっさと回復しとけ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_129_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>チクショウ……こんくらいで負けっかよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_130_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなもんじゃねェぞ、コラァ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_131_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>諦めるとかアリえねェだろ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_132_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
