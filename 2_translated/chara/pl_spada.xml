<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Spada</JapaneseText>
      <EnglishText>Spada</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いくぞ、コラァ！</JapaneseText>
      <EnglishText>Let's go, asshole!</EnglishText>
      <Notes>Audio file: na/NA04_100_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>暴れてんじゃねェぞ！</JapaneseText>
      <EnglishText>Quit bein' so aggressive!</EnglishText>
      <Notes>Audio file: na/NA04_101_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>邪魔すんじゃねェよ！　どけコラァ！</JapaneseText>
      <EnglishText>Don't get in my way! Outta the way, asshole!</EnglishText>
      <Notes>Audio file: na/NA04_102_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>怪我したくねェんだったら失せな</JapaneseText>
      <EnglishText>If ya don't wanna get hurt, get outta here.</EnglishText>
      <Notes>Audio file: na/NA04_103_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さっさと片付けてやンよ</JapaneseText>
      <EnglishText>Gonna hurry and clean this right up.</EnglishText>
      <Notes>Audio file: na/NA04_104_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>沈められてェのか？　アァ？</JapaneseText>
      <EnglishText>You want me to knock ya out? Huh?</EnglishText>
      <Notes>Audio file: na/NA04_105_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>仰々しいモン作りやがって</JapaneseText>
      <EnglishText>They made somethin' so over the top.</EnglishText>
      <Notes>Audio file: na/NA04_106_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>世界樹ってのはご立派だなァ、おい</JapaneseText>
      <EnglishText>The World Tree is impressive, huh.</EnglishText>
      <Notes>Audio file: na/NA04_107_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>話にならねェなぁ！</JapaneseText>
      <EnglishText>Ain't possible to slow me down!</EnglishText>
      <Notes>Audio file: na/NA04_108_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どんどんかかってこいよぉ！</JapaneseText>
      <EnglishText>Hurry and bring it on!</EnglishText>
      <Notes>Audio file: na/NA04_109_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんなに斬り刻まれてェのか？</JapaneseText>
      <EnglishText>Ya really wanna be chopped up that bad, huh?</EnglishText>
      <Notes>Audio file: na/NA04_110_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ハンッ！　ウゼェだけだな</JapaneseText>
      <EnglishText>Hmph! You're just annoyin'.</EnglishText>
      <Notes>Audio file: na/NA04_111_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>相手にならねェなぁ！</JapaneseText>
      <EnglishText>This ain't an opponent I can beat!</EnglishText>
      <Notes>Audio file: na/NA04_112_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>覚悟は出来てンだろうなぁ？</JapaneseText>
      <EnglishText>You ready for this?</EnglishText>
      <Notes>Audio file: na/NA04_113_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレの邪魔すンじゃねェよ！</JapaneseText>
      <EnglishText>Don't get in my way!</EnglishText>
      <Notes>Audio file: na/NA04_114_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなもんかぁ？　あぁ？</JapaneseText>
      <EnglishText>That all ya got? Huh?</EnglishText>
      <Notes>Audio file: na/NA04_115_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ほら、さっさと次来いよ！</JapaneseText>
      <EnglishText>C'mon, let's hurry to the next one!</EnglishText>
      <Notes>Audio file: na/NA04_116_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ハナシにもなんねェぞ！</JapaneseText>
      <EnglishText>This ain't even worth it!</EnglishText>
      <Notes>Audio file: na/NA04_117_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>怪我してェのかよ！</JapaneseText>
      <EnglishText>You tryin' to get hurt?!</EnglishText>
      <Notes>Audio file: na/NA04_118_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あー、ウッゼェな！</JapaneseText>
      <EnglishText>Ahhh, so annoyin'!</EnglishText>
      <Notes>Audio file: na/NA04_119_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>斬られても文句は言うなよ？</JapaneseText>
      <EnglishText>Don't complain if I slice ya up, gotcha?</EnglishText>
      <Notes>Audio file: na/NA04_120_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>覚悟もねェのに出てくんな！</JapaneseText>
      <EnglishText>Don't come out here if ya ain't prepared!</EnglishText>
      <Notes>Audio file: na/NA04_121_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>21</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>死なねェ程度には手ェ抜いてやったぞ</JapaneseText>
      <EnglishText>I held back so ya wouldn't die.</EnglishText>
      <Notes>Audio file: na/NA04_122_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>22</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まさかそのくれェで降参しねェよなぁ？</JapaneseText>
      <EnglishText>Ya ain't givin' up that easy, are ya?</EnglishText>
      <Notes>Audio file: na/NA04_123_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>23</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もっとふんばれや！</JapaneseText>
      <EnglishText>Hang in there!</EnglishText>
      <Notes>Audio file: na/NA04_124_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>24</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ヤバかったらさっさと逃げろ！</JapaneseText>
      <EnglishText>If this gets nasty, hurry and get outta here!</EnglishText>
      <Notes>Audio file: na/NA04_125_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>25</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>とっとと行くぞ</JapaneseText>
      <EnglishText>Let's hurry an' go!</EnglishText>
      <Notes>Audio file: na/NA04_126_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>26</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ザコがウジャウジャ出てくンじゃねェよ！</JapaneseText>
      <EnglishText>Don't you small fry be comin' out here in droves like this!</EnglishText>
      <Notes>Audio file: na/NA04_127_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>27</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>万倍にして後悔させてやらぁ</JapaneseText>
      <EnglishText>I'll make ya regret this ten thousand times over.</EnglishText>
      <Notes>Audio file: na/NA04_128_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>28</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>テメェはさっさと回復しとけ！</JapaneseText>
      <EnglishText>Ya better recover fast, bucko!</EnglishText>
      <Notes>Audio file: na/NA04_129_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>29</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>チクショウ……こんくらいで負けっかよ</JapaneseText>
      <EnglishText>Dammit... I ain't losin' to somethin' like this.</EnglishText>
      <Notes>Audio file: na/NA04_130_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>30</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなもんじゃねェぞ、コラァ！</JapaneseText>
      <EnglishText>This much is nothin', ya asshole!</EnglishText>
      <Notes>Audio file: na/NA04_131_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>31</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>諦めるとかアリえねェだろ！</JapaneseText>
      <EnglishText>No way am I givin' up!</EnglishText>
      <Notes>Audio file: na/NA04_132_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>32</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
</SceneText>
