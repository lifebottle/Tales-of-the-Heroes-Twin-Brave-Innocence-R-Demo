<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Thief RTM</JapaneseText>
      <EnglishText>Thief RTM</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いってぇー！　タンコブ出来ちまったー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_400_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>強ぇ！　あんなのが相手なんて聞いてねぇぜ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_401_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ウゲェ、あいつメチャクチャ強いじゃねぇーか！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_402_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺らの悪行にマジになっちゃってどーすんのよ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_403_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>痛い目に遭うなら賊はやめだ！　明日から働くぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_404_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ひゃっはー！　ブチのめしてやろうぜ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_405_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ひゃっはー！　ブチのめされちまったぜ…</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_406_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんな強い奴が相手なんて、冗談じゃないよー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_407_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>タダモンじゃねぇぞ！　油断すんな！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_408_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こっから本気出す！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_409_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ムチャクチャにしてやろうぜー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_410_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>何か楽しくなってきたぜ！　うひょー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_411_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オラオラ！　道をあけやがれ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_412_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ううぅ、足がすくむぜ…</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_413_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ひぃぃ！　俺の…俺の足が…肉離れに…</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_414_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ドサクサに紛れて俺は逃げるぜ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_415_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ひっぐ、なにずんだよー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_416_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>野郎！　これ以上はさせねぇー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_417_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>つ、強ぇ！　兄貴と呼ばせてくれ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_418_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>邪魔するならブッ潰す！　邪魔しなくてもブッ潰す！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_419_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>強ぇ…ボコられてんのに、憧れちまうぜ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_420_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺らは負けねぇ！　そこんとこヨロシク！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_421_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>母ちゃんの為ならえんやこら！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_422_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>お前らなんか大嫌いだ！　ろくなもんじゃねぇ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_423_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>金目のもんを置いて行けー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_424_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺らと出会った不幸を呪いやがれ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_425_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>イイ加減に潰れろ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_426_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これ以上はやらせねぇぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_427_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺達ァ健康優良犯罪集団だぜ！！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_428_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うわぁ！　仲間の首が！　ムチウチに！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_429_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そう簡単に終わってたまるかよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_430_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>数だ！　数で押し切るしかねぇ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_431_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>テメーら、ビビるんじゃねぇぞー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_432_301.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
