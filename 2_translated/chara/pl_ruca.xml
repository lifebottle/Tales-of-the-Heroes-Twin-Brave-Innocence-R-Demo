<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Ruca</JapaneseText>
      <EnglishText>Ruca</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ぼ、僕がやらなきゃ……いけないんだよね？</JapaneseText>
      <EnglishText>I-I have to... do this, right?</EnglishText>
      <Notes>Audio file: na/NA04_100_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>被害が出る前に、戦いを終わらせなきゃ</JapaneseText>
      <EnglishText>We have to end this battle before
it causes any more damage.</EnglishText>
      <Notes>Audio file: na/NA04_101_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ど、どいてください！</JapaneseText>
      <EnglishText>P-Please move!</EnglishText>
      <Notes>Audio file: na/NA04_102_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>逃げないぞ。僕は……！</JapaneseText>
      <EnglishText>I won't run away...!</EnglishText>
      <Notes>Audio file: na/NA04_103_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕にだってやれるはずなんだ……！</JapaneseText>
      <EnglishText>I can do it, too...!</EnglishText>
      <Notes>Audio file: na/NA04_104_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>水に落っこちたりしたら、大変だよね……</JapaneseText>
      <EnglishText>It'd be bad if I fell into the water...</EnglishText>
      <Notes>Audio file: na/NA04_105_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>この遺跡、なんなんだろう……</JapaneseText>
      <EnglishText>What are these ruins...?</EnglishText>
      <Notes>Audio file: na/NA04_106_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>世界樹……これが？</JapaneseText>
      <EnglishText>Is this... the World Tree?</EnglishText>
      <Notes>Audio file: na/NA04_107_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>や、やったんだよね？</JapaneseText>
      <EnglishText>D-Did I do it?</EnglishText>
      <Notes>Audio file: na/NA04_108_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>倒した？　倒せたの？</JapaneseText>
      <EnglishText>Did I beat them? I beat them, right?</EnglishText>
      <Notes>Audio file: na/NA04_109_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ま、まぐれじゃない。僕だってやれるんだ</JapaneseText>
      <EnglishText>I-It wasn't just luck. I can do this, too.</EnglishText>
      <Notes>Audio file: na/NA04_110_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うわっ！　え？　あ、倒せたの？</JapaneseText>
      <EnglishText>Whoa! Huh? Oh, did I beat them?</EnglishText>
      <Notes>Audio file: na/NA04_111_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>勇気を出さなきゃ……</JapaneseText>
      <EnglishText>I have to be brave...</EnglishText>
      <Notes>Audio file: na/NA04_112_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どいてよ！　傷つけたくないんだ！</JapaneseText>
      <EnglishText>Move aside! I don't want to hurt you!</EnglishText>
      <Notes>Audio file: na/NA04_113_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>向かってくるから！</JapaneseText>
      <EnglishText>They're coming toward us!</EnglishText>
      <Notes>Audio file: na/NA04_114_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>14</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>た、倒せたんだよね……？</JapaneseText>
      <EnglishText>I-I defeated them, right...?</EnglishText>
      <Notes>Audio file: na/NA04_115_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>15</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>い、今の感じを忘れなければ……</JapaneseText>
      <EnglishText>I-If only I could just forget what I'm feeling right now...</EnglishText>
      <Notes>Audio file: na/NA04_116_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>仲間には手を出させないぞ</JapaneseText>
      <EnglishText>I won't let you lay a hand on my companion.</EnglishText>
      <Notes>Audio file: na/NA04_117_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>17</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ごめんなさい！　痛かった？</JapaneseText>
      <EnglishText>I'm sorry! Did I hurt you?</EnglishText>
      <Notes>Audio file: na/NA04_118_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>18</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わわ、やりすぎちゃったかな？</JapaneseText>
      <EnglishText>Oh gosh, did I go too far?</EnglishText>
      <Notes>Audio file: na/NA04_119_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>19</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ああ、もう！　どうして襲ってくるの？</JapaneseText>
      <EnglishText>Ah, enough already! Why am I being attacked?</EnglishText>
      <Notes>Audio file: na/NA04_120_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>20</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あんまり怪我させないようにしなきゃ……</JapaneseText>
      <EnglishText>I have to be careful not to hurt them too much...</EnglishText>
      <Notes>Audio file: na/NA04_121_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>21</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あなた達とは戦いたくないのに！</JapaneseText>
      <EnglishText>I don't wanna fight you guys!</EnglishText>
      <Notes>Audio file: na/NA04_122_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>22</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>傷が増えてきてるよ。気をつけて</JapaneseText>
      <EnglishText>You're getting more wounds. Be careful.</EnglishText>
      <Notes>Audio file: na/NA04_123_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>23</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そろそろ危ないよ。大丈夫？</JapaneseText>
      <EnglishText>This is getting pretty dangerous. Are you okay?</EnglishText>
      <Notes>Audio file: na/NA04_124_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>24</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>逃げて！　ここは僕が……僕がなんとかするから！</JapaneseText>
      <EnglishText>Run! I'll... I'll do something about this!</EnglishText>
      <Notes>Audio file: na/NA04_125_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>25</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>進まなきゃ……やっぱりだめだよね？</JapaneseText>
      <EnglishText>I have to keep going... You really won't move?</EnglishText>
      <Notes>Audio file: na/NA04_126_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>26</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>また敵！？　こんなときに……！</JapaneseText>
      <EnglishText>Another enemy?! At a time like this...!</EnglishText>
      <Notes>Audio file: na/NA04_127_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>27</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うわ！！　ま、まだやられないよ！</JapaneseText>
      <EnglishText>Whoa!! Y-You've almost beaten them!</EnglishText>
      <Notes>Audio file: na/NA04_128_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>28</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>大丈夫？　回復を最優先に考えてね</JapaneseText>
      <EnglishText>Are you okay? You should think
about prioritizing recovering.</EnglishText>
      <Notes>Audio file: na/NA04_129_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>29</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やっぱり僕じゃ……無理だったのかな？</JapaneseText>
      <EnglishText>I guess I... wasn't able to do it, after all...</EnglishText>
      <Notes>Audio file: na/NA04_130_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>30</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もっとやれる！　僕だって！</JapaneseText>
      <EnglishText>I can do more! Even I can!</EnglishText>
      <Notes>Audio file: na/NA04_131_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>31</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>諦めちゃだめだ。最後までやらないと！</JapaneseText>
      <EnglishText>I can't give up. I have to follow through
with this all the way to the end!</EnglishText>
      <Notes>Audio file: na/NA04_132_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>32</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
</SceneText>
