<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Ruca</JapaneseText>
      <EnglishText>Ruca</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ぼ、僕がやらなきゃ……いけないんだよね？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_100_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>被害が出る前に、戦いを終わらせなきゃ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_101_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ど、どいてください！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_102_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>逃げないぞ。僕は……！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_103_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>僕にだってやれるはずなんだ……！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_104_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>水に落っこちたりしたら、大変だよね……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_105_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>この遺跡、なんなんだろう……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_106_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>世界樹……これが？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_107_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>や、やったんだよね？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_108_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>倒した？　倒せたの？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_109_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ま、まぐれじゃない。僕だってやれるんだ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_110_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うわっ！　え？　あ、倒せたの？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_111_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>勇気を出さなきゃ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_112_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>どいてよ！　傷つけたくないんだ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_113_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>向かってくるから！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_114_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>た、倒せたんだよね……？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_115_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>い、今の感じを忘れなければ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_116_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>仲間には手を出させないぞ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_117_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ごめんなさい！　痛かった？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_118_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>わわ、やりすぎちゃったかな？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_119_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ああ、もう！　どうして襲ってくるの？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_120_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あんまり怪我させないようにしなきゃ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_121_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あなた達とは戦いたくないのに！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_122_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>傷が増えてきてるよ。気をつけて</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_123_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そろそろ危ないよ。大丈夫？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_124_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>逃げて！　ここは僕が……僕がなんとかするから！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_125_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>進まなきゃ……やっぱりだめだよね？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_126_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>また敵！？　こんなときに……！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_127_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うわ！！　ま、まだやられないよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_128_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>大丈夫？　回復を最優先に考えてね</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_129_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やっぱり僕じゃ……無理だったのかな？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_130_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もっとやれる！　僕だって！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_131_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>諦めちゃだめだ。最後までやらないと！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_132_019.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
