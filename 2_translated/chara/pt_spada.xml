<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Spada</JapaneseText>
      <EnglishText>Spada</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>気合い入ってんだろうなぁ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_200_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ったく、しゃーねェな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_201_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ンじゃあ手加減はしねェからな！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_202_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さっさと行こうぜ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_203_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ザコばっかじゃつまんねェんだがなぁ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_204_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>少しゃ楽しませろよな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_205_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ビビッてねェで行くぞ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_206_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さぁて、いざいこうか！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_207_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんなもんかぁ！？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_208_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やるじゃねェかよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_209_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さっさと次いけや！　ぼーっとすンな！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_210_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>悪くはねェんじゃねェの？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_211_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ボチボチってとこか？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_212_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>もっと早く片付けらんねェのかよ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_213_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>その程度の奴に時間かけてンじゃねェよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_214_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>悪くねェ技だったぜ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_215_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まだまだキレがたんねェなぁ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_216_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなもんで満足すんなよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_217_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>適当に手加減してやれよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_218_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まさか手こずってねェよなぁ！？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_219_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>覚悟もねェのに武器持つンじゃねェ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_220_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>秒殺もできねェのかよ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_221_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>その調子でやっちまいな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_222_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>何人斬るつもりだぁ？　やるじゃねぇかよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_223_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレの獲物まで奪うンじゃねェぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_224_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ヤリすぎなんじゃねェか？　さすがによ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_225_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>一騎当千の仲間とは、誉れ高いぜ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_226_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>止まるな！　もっとやり続けろや！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_227_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>イイ感じじゃねェか</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_228_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オマエの前に敵はなしってか？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_229_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>その調子で全員巻き込ンじまえ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_230_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>終わらない攻撃ってのはタマンねェなぁ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_231_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>この戦場は、もうオマエのモンだ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_232_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まだそんな程度かよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_233_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>33</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オッセェよ！　もっと上に来いっての！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_234_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>34</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>少しはヤルようになったンじゃね？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_235_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>35</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>一騎打ちしてみてェもんだ、オマエとよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_236_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>36</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ここまでの武人はそう見れねェな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_237_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>37</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オマエの剣である事、誇りに思うぜ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_238_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>38</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そんくらいの怪我でビビッてねェよなぁ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_239_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>39</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>体力なんざ、気合いで回復しろ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_240_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>40</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ヤッベェじゃねェか！　いったん下がれ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_241_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>41</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>なにやってンだ？　さっさと行くぜ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_242_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>42</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ザコがぁ！　数だけは立派だなぁ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_243_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>43</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>油断してんじゃねェよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_244_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>44</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>マジで大丈夫なのかよ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_245_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>45</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>剣は……決して折れちゃいけねェんだ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_246_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>46</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>オレを置いてくとはイイ度胸してんなぁ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_247_020.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>47</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
