<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Emil</JapaneseText>
      <EnglishText>Emil</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ふんっ、少しはデキるみてぇだな</JapaneseText>
      <EnglishText>Hmph. Looks like they're actually a little bit capable.</EnglishText>
      <Notes>Audio file: na/NA04_300_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>認めてやってもいいぜ、おまえの事</JapaneseText>
      <EnglishText>I guess I can give 'em a little credit.</EnglishText>
      <Notes>Audio file: na/NA04_301_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いつまでも調子のってんじゃねぇ！</JapaneseText>
      <EnglishText>Don't think you can be cocky forever!</EnglishText>
      <Notes>Audio file: na/NA04_302_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>来いよ。俺が相手になってやる！</JapaneseText>
      <EnglishText>Come. I'll be your opponent!</EnglishText>
      <Notes>Audio file: na/NA04_303_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いい動きしてる奴がいるな</JapaneseText>
      <EnglishText>They have good moves.</EnglishText>
      <Notes>Audio file: na/NA04_304_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>あいつ、なかなかおもしれぇじゃねぇか</JapaneseText>
      <EnglishText>They're pretty interesting, huh?</EnglishText>
      <Notes>Audio file: na/NA04_305_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>いい気になってんじゃねぇぞ</JapaneseText>
      <EnglishText>Don't get carried away.</EnglishText>
      <Notes>Audio file: na/NA04_306_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>まだ止められないのかよ……！</JapaneseText>
      <EnglishText>Am I still not able to stop them...?!</EnglishText>
      <Notes>Audio file: na/NA04_307_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>圧倒的だな……</JapaneseText>
      <EnglishText>This is overwhelming...</EnglishText>
      <Notes>Audio file: na/NA04_308_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺は負けねぇからな……</JapaneseText>
      <EnglishText>I won't lose...</EnglishText>
      <Notes>Audio file: na/NA04_309_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺を怒らせたいらしいな！</JapaneseText>
      <EnglishText>Looks like you wanna piss me off!</EnglishText>
      <Notes>Audio file: na/NA04_310_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>逃げんなよ</JapaneseText>
      <EnglishText>I won't let you escape!</EnglishText>
      <Notes>Audio file: na/NA04_311_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>Proofreading</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>死んでも恨むんじゃねぇぞ！</JapaneseText>
      <EnglishText>Don't hold a grudge against me if you die!</EnglishText>
      <Notes>Audio file: na/NA04_312_036.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>Proofreading</Status>
    </Entry>
  </Strings>
</SceneText>
