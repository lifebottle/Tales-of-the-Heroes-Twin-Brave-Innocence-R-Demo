<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Commoner RTM</JapaneseText>
      <EnglishText>Commoner RTM</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ひー！　死ぬかと思ったー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_400_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんな事なら部屋から出なけりゃ良かったぜ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_401_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>この野郎！　もう容赦しねぇぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_402_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こうなりゃ意地だ！　負けねぇぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_403_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ぶっちゃけると、俺らにはケンカしか娯楽がねぇーんだ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_404_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>やったるぜー！　俺らの力、見くびるな！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_405_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>かかってこいやー！　ビビったりしねーぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_406_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺らが黙ってやられると思うんじゃねぇーぞ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_407_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>タダじゃやられねぇぞ！　</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_408_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>行け行けー！　俺らが負けるわけねぇー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_409_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺より強い奴はどこにいるんだー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_410_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>何するだぁー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_411_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺らの事、見くびるとケガするぜ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_412_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>本気で叩く事ないだろ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_413_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>13</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>とんでもねぇ…</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_414_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>14</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>アイツを怒らせたのはマズかったか！？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_415_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>15</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>敵はハンパじゃねぇ！　皆も気合入れろ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_416_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>16</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>この野郎！　もう容赦しねぇ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_417_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>17</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>俺らには俺らの事情があるんだよ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_418_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>18</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ヨソモンにデカイ面はさせねぇ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_419_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>19</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こんなでけぇタンコブ見たことねぇ…</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_420_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>20</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>強ぇ！　見た目と全然違うじゃねぇーか！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_421_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>21</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>冗談みてぇに強い野郎だ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_422_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>22</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ケンカ売る相手を選ぶべきだったな！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_423_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>23</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>うげぇ！　今のはきいたぁ〜</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_424_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>24</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ちょい待ち！　腰が抜けたぁ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_425_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>25</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ダメだ、勝てっこねぇ…</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_426_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>26</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>負けっぱなしじゃ終われねぇ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_427_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>27</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>勝てる気がしねぇ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_428_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>28</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>強ぇ！　惚れちまいそうだ！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_429_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>29</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ヤベェ！　こいつらシャレになんねー！</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_430_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>30</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>何食ったらあんなに強くなるんだ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_431_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>31</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ヤバい相手にケンカを売っちまった…</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_432_302.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>32</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
