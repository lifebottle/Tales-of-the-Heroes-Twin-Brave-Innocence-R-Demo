<SceneText>
  <Speakers>
    <Section>Speaker</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>Yuri</JapaneseText>
      <EnglishText>Yuri</EnglishText>
      <Notes/>
      <Id>0</Id>
      <Status>Done</Status>
    </Entry>
  </Speakers>
  <Strings>
    <Section>System</Section>
    <Entry>
      <PointerOffset/>
      <JapaneseText>これ以上は見逃せねぇな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_300_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>0</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さすがにやばいだろ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_301_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>1</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>くっ、止められねぇのか</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_302_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>2</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こりゃあまいったな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_303_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>3</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>楽に勝てる相手じゃ、なさそうだな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_304_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>4</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>おいおい、いつまで続くんだ？</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_305_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>5</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こりゃあ予想以上だな……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_306_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>6</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>デキるなんてもんじゃねぇぞ……</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_307_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>7</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>さすがにまいったな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_308_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>8</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>こりゃあ厳しい戦いになりそうだな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_309_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>9</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>そうきたか……腹くくれよ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_310_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>10</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>ま、退いちゃくれねぇだろうな</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_311_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>11</Id>
      <Status>To Do</Status>
    </Entry>
    <Entry>
      <PointerOffset/>
      <JapaneseText>悪いが、どいてやるつもりはないぜ</JapaneseText>
      <EnglishText/>
      <Notes>Audio file: na/NA04_312_023.na</Notes>
      <SpeakerId>0</SpeakerId>
      <Id>12</Id>
      <Status>To Do</Status>
    </Entry>
  </Strings>
</SceneText>
